# Production Environment Variables
# Copy to .env and fill in your values

# ============================================
# Supabase Configuration
# ============================================
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ============================================
# Security
# ============================================
JWT_SECRET=your-jwt-secret-key-here-minimum-32-chars
ENCRYPTION_KEY=your-32-character-encryption-key

# ============================================
# AI Configuration
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key

# ============================================
# Redis (Railway auto-populates REDIS_URL)
# ============================================
# For Railway: Link a Redis plugin - REDIS_URL is auto-set
# For self-hosting: Set these manually
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# Server Configuration
# ============================================
PORT=3001
NODE_ENV=production

# ============================================
# Platform Mode
# ============================================
# 'direct' - Uses native platform adapters (whatsapp-web.js, telegraf, etc.)
# 'matrix' - Uses Matrix bridges via Synapse homeserver (mautrix-*)
PLATFORM_MODE=direct

# ============================================
# Direct Mode Configuration
# ============================================
# WhatsApp (direct mode)
WHATSAPP_SESSION_PATH=/app/sessions
PUPPETEER_HEADLESS=true

# Telegram (direct mode) - Get from @BotFather
TELEGRAM_BOT_TOKEN=

# Platform toggles
TELEGRAM_ENABLED=true
IMESSAGE_ENABLED=false
INSTAGRAM_ENABLED=true

# ============================================
# Matrix Mode Configuration (PLATFORM_MODE=matrix)
# ============================================
MATRIX_HOMESERVER_URL=http://synapse:8008
MATRIX_SERVER_NAME=claire.local
MATRIX_ADMIN_TOKEN=
MATRIX_BOT_USER_ID=

# Synapse database password
SYNAPSE_DB_PASSWORD=synapse_secret

# Matrix port
MATRIX_PORT=8008

# Telegram API (required for mautrix-telegram)
# Get from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

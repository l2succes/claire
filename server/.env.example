# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-here-minimum-32-chars

# Encryption
ENCRYPTION_KEY=your-32-character-encryption-key

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Server Configuration
PORT=3001
NODE_ENV=development

# WhatsApp Web Configuration
WHATSAPP_SESSION_PATH=./sessions
PUPPETEER_HEADLESS=true

# Platform Configuration
TELEGRAM_ENABLED=true
IMESSAGE_ENABLED=true
INSTAGRAM_ENABLED=true

# ============================================
# Platform Mode
# ============================================
# 'direct' - Uses native platform adapters (whatsapp-web.js, telegraf, etc.)
# 'matrix' - Uses Matrix bridges via Synapse homeserver (mautrix-*)
PLATFORM_MODE=direct

# ============================================
# Matrix Configuration (required when PLATFORM_MODE=matrix)
# ============================================
# URL of your Synapse homeserver
MATRIX_HOMESERVER_URL=http://localhost:8008

# Your Matrix server name (domain)
MATRIX_SERVER_NAME=claire.local

# Admin access token for the Claire bot user
# Generate with: register_new_matrix_user -c /data/homeserver.yaml http://localhost:8008
MATRIX_ADMIN_TOKEN=

# Bot user ID (optional, defaults to @claire_bot:MATRIX_SERVER_NAME)
MATRIX_BOT_USER_ID=

# ============================================
# Telegram API (required for mautrix-telegram bridge)
# ============================================
# Get from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
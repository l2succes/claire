{
  "name": "@claire/client",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "env:pull:dev": "bunx eas env:pull --environment development --non-interactive",
    "env:pull:prod": "bunx eas env:pull --environment production --non-interactive",
    "start": "bun run env:pull:dev && bunx expo start",
    "start:prod": "bun run env:pull:prod && bunx expo start",
    "start:prod:local": "NODE_ENV=production bunx expo start",
    "dev": "bunx expo start",
    "android": "expo run:android",
    "ios": "bunx expo run:ios",
    "ios:prod": "bun run env:pull:prod && bunx expo run:ios",
    "ios:prod:local": "NODE_ENV=production bunx expo run:ios",
    "ios:prod:device": "bun run env:pull:prod && bunx expo run:ios -d",
    "ios:prod:device:local": "NODE_ENV=production bunx expo run:ios -d",
    "web": "bunx expo start --web",
    "build:dev": "bunx eas build --profile development --platform ios",
    "build:preview": "bunx eas build --profile preview --platform ios",
    "build:prod": "bunx eas build --profile production --platform ios",
    "test": "bunx jest",
    "test:watch": "bunx jest --watch",
    "lint": "bunx eslint . --ext .ts,.tsx",
    "lint:fix": "bunx eslint . --ext .ts,.tsx --fix",
    "typecheck": "bunx tsc --noEmit",
    "export": "bunx expo export",
    "export:web": "bunx expo export -p web",
    "e2e:web": "bunx playwright test"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@gluestack-ui/nativewind-utils": "^1.0.0",
    "@gluestack-ui/overlay": "^0.1.0",
    "@gluestack-ui/toast": "^1.0.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-cookies/cookies": "^6.0.0",
    "@react-navigation/core": "^7",
    "@react-navigation/elements": "^2",
    "@react-navigation/native": "^7",
    "@supabase/supabase-js": "^2.39.1",
    "@tanstack/react-query": "^5.14.2",
    "axios": "^1.6.2",
    "clsx": "^2.1.0",
    "date-fns": "^4.1.0",
    "expo": "~55.0.0",
    "expo-auth-session": "~55.0.10",
    "expo-constants": "~55.0.9",
    "expo-crypto": "~55.0.10",
    "expo-dev-client": "^55.0.19",
    "expo-device": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.9",
    "expo-notifications": "~55.0.14",
    "expo-router": "~55.0.8",
    "expo-splash-screen": "~55.0.13",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "~55.0.10",
    "lucide-react-native": "^0.294.0",
    "nativewind": "^4.0.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-gifted-chat": "^3.3.2",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-webview": "^13.0.0",
    "react-native-worklets": "~0.7.0",
    "tailwind-merge": "^2.2.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@babel/core": "^7.23.6",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.1",
    "@types/jest": "^29.5.11",
    "@types/react": "~19.2.10",
    "@types/react-native": "~0.73.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "eslint-config-expo": "~55.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.11",
    "react-test-renderer": "19.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3"
  },
  "private": true,
  "overrides": {
    "@react-navigation/core": "^7",
    "@react-navigation/native": "^7",
    "@react-navigation/elements": "^2"
  }
}

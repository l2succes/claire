# Matrix Bridge Configuration for Claire
# Copy this file to .env and fill in the values

# Server name (your domain or local identifier)
MATRIX_SERVER_NAME=claire.local

# Port to expose Synapse on
MATRIX_PORT=8008

# Database password for Synapse PostgreSQL
SYNAPSE_DB_PASSWORD=change_me_to_secure_password

# Synapse secrets (generate with: openssl rand -hex 32)
SYNAPSE_REGISTRATION_SECRET=change_me_generate_with_openssl
SYNAPSE_MACAROON_SECRET=change_me_generate_with_openssl
SYNAPSE_FORM_SECRET=change_me_generate_with_openssl

# Telegram API credentials (required for mautrix-telegram)
# Get from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Optional: Telegram bot token (if using bot mode)
TELEGRAM_BOT_TOKEN=

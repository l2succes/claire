{
  "name": "claire",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "cd server && bun run dev",
    "dev:client": "cd client && bun run dev",
    "dev:prod": "concurrently \"bun run dev:server\" \"bun run client:prod\"",
    "client:prod": "cd client && bun run start:prod",
    "client:prod:local": "cd client && bun run start:prod:local",
    "client:ios:prod": "cd client && bun run ios:prod",
    "client:ios:prod:local": "cd client && bun run ios:prod:local",
    "client:ios:prod:device": "cd client && bun run ios:prod:device",
    "client:ios:prod:device:local": "cd client && bun run ios:prod:device:local",
    "test": "bun run test:server && bun run test:client",
    "test:server": "cd server && bun test",
    "test:client": "cd client && bun test",
    "lint": "bun run lint:server && bun run lint:client",
    "lint:server": "cd server && bun run lint",
    "lint:client": "cd client && bun run lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "install:server": "cd server && bun install",
    "install:client": "cd client && bun install",
    "docker:up": "bun run docker:supabase && bun run docker:matrix",
    "docker:down": "bun run docker:supabase:down && bun run docker:matrix:down",
    "docker:supabase": "docker compose -f docker/supabase/docker-compose.supabase.yml up -d",
    "docker:supabase:down": "docker compose -f docker/supabase/docker-compose.supabase.yml down",
    "docker:supabase:logs": "docker compose -f docker/supabase/docker-compose.supabase.yml logs -f",
    "docker:matrix": "docker compose -f docker/matrix/docker-compose.matrix.yml up -d",
    "docker:matrix:down": "docker compose -f docker/matrix/docker-compose.matrix.yml down",
    "docker:matrix:logs": "docker compose -f docker/matrix/docker-compose.matrix.yml logs -f"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.1.1"
  }
}
